;-------------------------------------------------------------------------------
; hello.s32
; Prints Hello World!
;-------------------------------------------------------------------------------
    LDP text
    JSR printstr
    HLT
;-------------------------------------------------------------------------------
; print string at DP until 0 byte
;-------------------------------------------------------------------------------
printstr:
@loop:
    LDA             ; A = mem[DP]
    CMI $00         ; compare with null terminator
    JEQ @done
    PRT             ; print character
    IDP             ; DP++
    JMP @loop
@done:
    RET
;-------------------------------------------------------------------------------
; data
;-------------------------------------------------------------------------------
text:
    .ascii "Hello World!"
    .data $00       ; null terminator
;-------------------------------------------------------------------------------
; END OF FILE
;-------------------------------------------------------------------------------