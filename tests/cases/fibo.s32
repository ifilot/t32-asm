;-------------------------------------------------------------------------------
; fibo.s32
; Print the first 10 values of the Fibonacci series
;-------------------------------------------------------------------------------
start:
    ; initialize val1=0, val2=1, counter=0
    LDI 0
    LDP @val1
    STA
    IDP
    LDI 1
    STA
@next:
    LDP @val1       ; DP -> val1
    LDA             ; A = val1
    IDP             ; DP -> val2
    ADD             ; A = val1 + val2
    PSH             ; put new value onto stack
    JSR printdec    ; print sum, note, clobbers DP
    JSR printnl     ; and a newline
    LDP @val2       ; DP -> val2
    LDA             ; A = val2
    DDP             ; DP -> val1
    STA             ; val2 -> val1
    IDP             ; DP -> val2
    POP             ; A = newval
    STA             ; newval -> val2
    IDP             ; DP -> counter
    LDA             ; load counter
    ADI 1           ; increment counter
    STA             ; store counter
    CMI 12          ; yields 233 as largest value
    JEQ @done
    JMP @next
@done:
    HLT
@val1:
.data $00
@val2:
.data $00
@counter:
.data $00
;-------------------------------------------------------------------------------
; printdec
; Print unsigned integer as decimal value
; Retains A, Clobbers DP
;-------------------------------------------------------------------------------
printdec:
    PSH
    LDP @n
    STA
    LDI 0
    LDP @hundreds
    STA
    LDP @tens
    STA
    LDP @ones
    STA
    ; n -= 100 while n >= 100, hundreds++
@hundreds_loop:
    LDP @n
    LDA
    CMI 100
    JNG @tens_loop
@take_hundred:
    SBI 100
    LDP @n
    STA
    LDP @hundreds
    LDA
    ADI 1
    STA
    JMP @hundreds_loop
    ; n -= 10 while n >= 10, tens++
@tens_loop:
    LDP @n
    LDA
    CMI 10
    JNG @finish_digits
@take_ten:
    SBI 10
    LDP @n
    STA
    LDP @tens
    LDA
    ADI 1
    STA
    JMP @tens_loop
@finish_digits:
    ; remaining n is ones
    LDP @n
    LDA
    LDP @ones
    STA
    ; if hundreds != 0, print all three digits
    LDP @hundreds
    LDA
    CMI 0
    JEQ @check_tens
    LDP @hundreds
    JSR print_digit_at_dp
    LDP @tens
    JSR print_digit_at_dp
    LDP @ones
    JSR print_digit_at_dp
    JMP @done
    ; else, if tens != 0 print tens + ones
@check_tens:
    LDP @tens
    LDA
    CMI 0
    JEQ @print_ones_only
    LDP @tens
    JSR print_digit_at_dp
    LDP @ones
    JSR print_digit_at_dp
    JMP @done
    ; else print only ones
@print_ones_only:
    LDP @ones
    JSR print_digit_at_dp
@done:
    POP
    RET
;-------------------------------------------------------------------------------
; Data
;-------------------------------------------------------------------------------
@n:
    .data 0
@hundreds:
    .data 0
@tens:
    .data 0
@ones:
    .data 0
;-------------------------------------------------------------------------------
; print_digit_at_dp
; Expects DP -> value 0..9, prints ASCII digit.
;-------------------------------------------------------------------------------
print_digit_at_dp:
    LDA
    ADI 48
    PRT
    RET
;-------------------------------------------------------------------------------
; Print newline
;-------------------------------------------------------------------------------
printnl:
    PSH
    LDI $0A
    PRT
    POP
    RET
;-------------------------------------------------------------------------------
; END OF FILE
;-------------------------------------------------------------------------------