;-------------------------------------------------------------------------------
; int2dec.s32
; Converts an 8-bit unsigned integer to decimal ASCII
; and prints the human-readable string.
;-------------------------------------------------------------------------------
start:
    RTR
    JSR printdec
    HLT
;-------------------------------------------------------------------------------
; printdec
; Print unsigned integer as decimal value
;-------------------------------------------------------------------------------
printdec:
    LDP @n
    STA
; reset counters
    LDI 0
    LDP @hundreds
    STA
    LDP @tens
    STA
    LDP @ones
    STA
; n -= 100 while n >= 100, hundreds++
@hundreds_loop:
    LDP @n
    LDA
    CMI 100
    JNG @tens_loop
@take_hundred:
    SBI 100
    LDP @n
    STA
    LDP @hundreds
    LDA
    ADI 1
    STA
    JMP @hundreds_loop
    ; n -= 10 while n >= 10, tens++
@tens_loop:
    LDP @n
    LDA
    CMI 10
    JNG @finish_digits
@take_ten:
    SBI 10
    LDP @n
    STA
    LDP @tens
    LDA
    ADI 1
    STA
    JMP @tens_loop
@finish_digits:
    ; remaining n is ones
    LDP @n
    LDA
    LDP @ones
    STA
    ; if hundreds != 0, print all three digits
    LDP @hundreds
    LDA
    CMI 0
    JEQ @check_tens
    LDP @hundreds
    JSR print_digit_at_dp
    LDP @tens
    JSR print_digit_at_dp
    LDP @ones
    JSR print_digit_at_dp
    JMP @done
    ; else, if tens != 0 print tens + ones
@check_tens:
    LDP @tens
    LDA
    CMI 0
    JEQ @print_ones_only
    LDP @tens
    JSR print_digit_at_dp
    LDP @ones
    JSR print_digit_at_dp
    JMP @done
    ; else print only ones
@print_ones_only:
    LDP @ones
    JSR print_digit_at_dp
@done:
    RET
;-------------------------------------------------------------------------------
; Data
;-------------------------------------------------------------------------------
@n:
    .data 0
@hundreds:
    .data 0
@tens:
    .data 0
@ones:
    .data 0
;-------------------------------------------------------------------------------
; print_digit_at_dp
; Expects DP -> value 0..9, prints ASCII digit.
;-------------------------------------------------------------------------------
print_digit_at_dp:
    LDA
    ADI 48
    PRT
    RET
;-------------------------------------------------------------------------------
; END OF FILE
;-------------------------------------------------------------------------------