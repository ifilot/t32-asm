;-------------------------------------------------------------------------------
; int2hex.s32
; Converts an 8 bit unsigned integer to hexadecimal output
;-------------------------------------------------------------------------------
start:
    RTR
    JSR printhex
    HLT
;-------------------------------------------------------------------------------
; printhex
; Convert value in A to hex
;-------------------------------------------------------------------------------
printhex:
    PSH                 ; push to stack
    SHR
    SHR
    SHR
    SHR                 ; shift right 4
    JSR printnibble
    POP                 ; retrieve original value
    JSR printnibble
    RET
;-------------------------------------------------------------------------------
; printnibble
; Convert value in A to hex
;-------------------------------------------------------------------------------
printnibble:
    LDP @const
    AND
    CMI 10
    JNG @lt10
    ADI 55
    JMP @end
@lt10:
    ADI 48
@end:
    PRT
    RET
@const:         
.data $0F
;-------------------------------------------------------------------------------
; END OF FILE
;-------------------------------------------------------------------------------